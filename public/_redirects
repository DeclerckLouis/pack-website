# 301 redirect map for the Odoo → Astro migration.
# Format: Netlify / Cloudflare Pages `_redirects`. The trailing `301!` forces
# the redirect even if a file exists. Old paths below are the real indexed
# Odoo URLs from Google Search Console (Pages export).
#
# LAUNCH BLOCKER (only relevant once the site moves to packetflow.be): without
# these, the ranking + backlink equity of the old URLs is lost.
#
# NOTE: comments must be on their own line. Cloudflare Pages does not reliably
# parse a trailing `# comment` after a rule — it silently drops the rule (this
# is why /kmo-pakket stopped redirecting). Keep annotations above the rule.

# ---- Canonical host: keep www (the host Odoo ranks on), 301 the apex ----
https://packetflow.be/*   https://www.packetflow.be/:splat   301!

# ---- Old Odoo paths → new equivalents (from GSC) ----
# /diensten/it-beheer — 493 impressions
/diensten/it-beheer        /diensten/it-beheer-support           301
# /kmo-pakket — 377 impressions
/kmo-pakket                /pakket                               301
/diensten/wifi-netwerk     /diensten/zakelijke-wifi-netwerken    301
/sectoren/vrije-beroepen   /sectoren/kantoren-vrije-beroepen     301
/contactus                 /contact                              301
# /cookie-policy (Odoo) → privacy page
/cookie-policy             /privacy                              301
# /appointment/1 — Odoo appointment page
/appointment/1             /contact                              301

# ---- Second GSC pass (discovered/404 URLs, see issue #32) ----
# Old service/sector slugs that changed.
/diensten/backup-beveiliging   /diensten/cloud-backup-beveiliging   301
/sectoren/horeca               /sectoren/horeca-bnb                  301
# Odoo booking pages → contact (where the "plan een gesprek" CTA lives).
/calendar                  /contact                              301
/appointment               /contact                              301
# Odoo support portal (helpdesk + knowledgebase) → contact.
/helpdesk                  /contact                              301
/helpdesk/*                /contact                              301
# Old default-language about slug (the /en/ variant is handled below).
/about-me                  /over-mij                             301
# /terms — privacy is the only legal page.
/terms                     /privacy                              301

# English pages → Dutch equivalents (site is nl-only now).
# Specific rules must come BEFORE the /en/* catch-all (first match wins).
/en/contactus              /contact                              301
/en/about-me               /over-mij                             301
/en/privacy                /privacy                              301
/en/cookie-policy          /privacy                              301
/en/diensten/it-beheer-ondersteuning  /diensten/it-beheer-support  301
/en/*                      /                                     301

# Unchanged slugs (/, /over-mij, /privacy) need no redirect.
#
# NOTE: lab.packetflow.be (homelab) is a separate subdomain — out of scope here
# (its GSC entries can't be handled from this Pages _redirects file).
# NOTE: /cdn-cgi/l/email-protection is a Cloudflare-internal path, not a page —
# deliberately not redirected.

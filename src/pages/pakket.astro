---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CtaSection from "@/components/CtaSection.astro";
import { site } from "@/data/site";

const includes = [
  {
    title: "Microsoft 365",
    body: "E-mail, Teams, Office-apps en gebruikersbeheer — correct opgezet, beveiligd en up-to-date gehouden.",
  },
  {
    title: "Backup",
    body: "Automatische, geteste back-ups van je bestanden én je Microsoft 365-omgeving. Nooit nog data kwijt.",
  },
  {
    title: "Peppol & e-facturatie",
    body: "Klaar voor de verplichte e-facturatie via Peppol, correct geïntegreerd in je werking.",
  },
  {
    title: "Cybersecurity",
    body: "Meerlaagse bescherming tegen ransomware, phishing en datalekken, met monitoring en opvolging.",
  },
  {
    title: "Proactief beheer",
    body: "Monitoring en onderhoud van je werkplekken en systemen — problemen opgelost vóór ze je raken.",
  },
  {
    title: "Support inbegrepen",
    body: "Een vast, lokaal aanspreekpunt dat je omgeving kent. Snel bereikbaar wanneer je het nodig hebt.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Managed IT-pakket voor KMO's",
  provider: { "@type": "LocalBusiness", name: site.legalName },
  areaServed: site.serviceArea,
  name: "KMO-Pakket",
  description:
    "Volledige IT-ontzorging voor KMO's: Microsoft 365, backup, Peppol en cybersecurity aan een vaste maandprijs.",
};
---

<BaseLayout
  title="KMO-Pakket — volledige IT-ontzorging aan een vaste maandprijs"
  description="Het KMO-Pakket bundelt Microsoft 365, backup, Peppol en cybersecurity in één vaste maandprijs. Volledige ontzorging voor je onderneming."
  jsonLd={jsonLd}
>
  <section class="border-b border-line bg-subtle">
    <div class="container-page py-20 text-center">
      <p class="inline-flex rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-brand">
        Het KMO-Pakket
      </p>
      <h1 class="mx-auto mt-5 max-w-3xl text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Volledige IT-ontzorging aan één vaste maandprijs.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        Alles wat je KMO nodig heeft om veilig, productief en in regel te
        werken — gebundeld in één pakket. Geen uurtje-factuurtje, geen
        verrassingen. Eén partner, één prijs.
      </p>
      <div class="mt-8 flex justify-center">
        <a href="/contact" class="btn-primary">Vraag je offerte op maat</a>
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold text-ink">Wat zit er in het pakket?</h2>
      <p class="mt-4 text-muted">
        Alles centraal beheerd, zodat jij je geen zorgen hoeft te maken over je IT.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        includes.map((item) => (
          <div class="rounded-card border border-line bg-white p-7">
            <div class="grid h-10 w-10 place-items-center rounded-lg bg-brand/10 font-bold text-brand">
              ✓
            </div>
            <h3 class="mt-4 text-lg font-bold text-ink">{item.title}</h3>
            <p class="mt-2 text-sm text-muted">{item.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-y border-line bg-subtle">
    <div class="container-page grid gap-8 py-16 md:grid-cols-3">
      {
        [
          {
            k: "Voorspelbaar",
            v: "Eén vaste maandprijs per gebruiker. Je weet exact waar je aan toe bent.",
          },
          {
            k: "Compleet",
            v: "Beheer, beveiliging, backup en support — alles onder één dak.",
          },
          {
            k: "Lokaal",
            v: `Een vast aanspreekpunt in ${site.serviceArea} dat je zaak echt kent.`,
          },
        ].map((b) => (
          <div>
            <h3 class="text-lg font-bold text-ink">{b.k}</h3>
            <p class="mt-2 text-sm text-muted">{b.v}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaSection
    title="Benieuwd wat het pakket voor jou kost?"
    body="We stellen een pakket samen op maat van je team en bezorgen je een heldere prijs per gebruiker."
  />
</BaseLayout>

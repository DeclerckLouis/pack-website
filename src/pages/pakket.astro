---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CtaSection from "@/components/CtaSection.astro";
import Card from "@/components/Card.astro";
import Badge from "@/components/Badge.astro";
import Kicker from "@/components/Kicker.astro";
import Icon from "@/components/Icon.astro";
import Button from "@/components/Button.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Reviews from "@/components/Reviews.astro";
import { site } from "@/data/site";
import { service, breadcrumbs } from "@/lib/schema";

// PRICING: an entry "vanaf" price — the package is scoped per kantoor, so the
// closing CTA ("op maat van uw team") and this headline stay consistent.
const price = "vanaf €99";
const priceUnit = "/ maand";

const includes = [
  ["mail", "Microsoft 365", "E-mail, agenda, Teams en licenties — opgezet, beveiligd en onderhouden."],
  ["database", "Veilige back-up", "Uw dossiers automatisch en versleuteld bewaard. Getest, niet gehoopt."],
  ["file-check", "Peppol e-facturatie", "Klaar voor de verplichte e-facturatie, gekoppeld aan uw boekhouding."],
  ["shield-check", "Cybersecurity & MFA", "Bescherming tegen phishing en ransomware, met AI-detectie van verdacht gedrag."],
  ["radar", "Proactieve monitoring", "Ik bewaak uw systemen en grijp in vóór er iets stilvalt."],
  ["life-buoy", "Support inbegrepen", "Eén vast aanspreekpunt, bereikbaar 's avonds en in het weekend."],
];

const crumbs: [string, string][] = [
  ["Home", "/"],
  ["KMO-Pakket", "/pakket"],
];

const jsonLd = [
  service({
    name: "KMO-Pakket",
    description:
      "Volledige IT-ontzorging voor kleine kantoren: Microsoft 365, backup, Peppol en cybersecurity aan een vaste maandprijs.",
    serviceType: "Managed IT-pakket",
  }),
  breadcrumbs(crumbs),
];
---

<BaseLayout
  title="KMO-Pakket — volledige IT-ontzorging aan een vaste maandprijs"
  description="Het KMO-Pakket bundelt Microsoft 365, backup, Peppol en cybersecurity in één vaste maandprijs. Volledige ontzorging voor uw kantoor, scherp geprijsd."
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container page-hero__in pakket-hero">
      <div>
        <Breadcrumbs items={crumbs} />
        <Kicker>Het KMO-Pakket</Kicker>
        <h1>Volledige ontzorging aan één vaste prijs</h1>
        <p class="lead page-hero__lead">
          Alles wat een klein kantoor nodig heeft om veilig en in regel te
          werken — gebundeld in één pakket. Geen uurtje-factuurtje, geen
          verrassingen. Eén partner, één vaste prijs.
        </p>
        <div class="page-hero__actions">
          <Button href="/contact" variant="primary" iconRight="arrow-right">Vraag uw offerte</Button>
        </div>
      </div>

      <Card raised class="price-card">
        <Badge tone="orange" dot>Meest gekozen</Badge>
        <div class="price">
          <span class="price__amount">{price}</span>
          <span class="price__unit">{priceUnit}</span>
        </div>
        <p class="price__note">
          Voor een klein kantoor, op maat van uw team. Maandelijks opzegbaar.
          Microsoft 365-licenties worden apart en aan kostprijs doorgerekend.
        </p>
        <ul class="checklist price__list">
          {
            ["Microsoft 365 & e-mail", "Back-up van uw dossiers", "Peppol e-facturatie", "Beveiliging & monitoring", "Support buiten de uren"].map((i) => (
              <li>
                <span class="check"><Icon name="check" size={14} /></span>
                <span>{i}</span>
              </li>
            ))
          }
        </ul>
        <Button href="/contact" variant="primary" size="lg" fullWidth iconRight="arrow-right">
          Start vrijblijvend
        </Button>
      </Card>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <Kicker>Wat zit erin?</Kicker>
        <h2>Alles centraal beheerd, zonder kopzorgen</h2>
      </div>
      <div class="pakket-grid">
        {
          includes.map(([icon, title, body]) => (
            <Card class="feature">
              <span class="feature__icon"><Icon name={icon} size={20} /></span>
              <h3>{title}</h3>
              <p>{body}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section pakket-why">
    <div class="container grid-3-plain">
      {
        [
          ["Voorspelbaar", "Eén vaste prijs. U weet exact waar u aan toe bent, elke maand."],
          ["Compleet", "Beheer, beveiliging, backup en support — alles onder één dak."],
          ["Lokaal", `Eén vast aanspreekpunt in ${site.serviceArea} dat uw zaak echt kent.`],
        ].map(([k, v]) => (
          <div>
            <h3 class="pakket-why__k">{k}</h3>
            <p class="pakket-why__v">{v}</p>
          </div>
        ))
      }
    </div>
  </section>

  <Reviews />

  <CtaSection
    title="Benieuwd wat het pakket voor uw kantoor kost?"
    body="Ik stel een pakket samen op maat van uw team en bezorg u een heldere prijs — vrijblijvend."
  />
</BaseLayout>

<style>
  .pakket-hero {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-7);
    align-items: center;
  }
  .price-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .price {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .price__amount {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--text-3xl);
    color: var(--text-strong);
    letter-spacing: -0.02em;
  }
  .price__unit {
    font-size: var(--text-md);
    color: var(--text-muted);
  }
  .price__note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
  }
  .price__list {
    margin: var(--space-2) 0;
  }
  .pakket-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .pakket-why {
    background: var(--paper);
    border-block: 1px solid var(--border-soft);
  }
  .grid-3-plain {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .pakket-why__k {
    font-size: var(--text-lg);
  }
  .pakket-why__v {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  @media (max-width: 880px) {
    .pakket-hero,
    .pakket-grid,
    .grid-3-plain {
      grid-template-columns: 1fr;
    }
  }
</style>

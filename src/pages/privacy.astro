---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Kicker from "@/components/Kicker.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { site } from "@/data/site";
import { breadcrumbs } from "@/lib/schema";

const crumbs: [string, string][] = [
  ["Home", "/"],
  ["Privacybeleid", "/privacy"],
];
const jsonLd = breadcrumbs(crumbs);
---

<BaseLayout title="Privacybeleid" description={`Privacybeleid van ${site.legalName}.`} jsonLd={jsonLd}>
  <section class="section">
    <div class="container privacy">
      <Breadcrumbs items={crumbs} />
      <Kicker>Juridisch</Kicker>
      <h1 class="privacy__title">Privacybeleid</h1>
      <div class="prose">
        <p>
          Dit is een tijdelijke placeholder voor het privacybeleid van
          {site.legalName}. Vervang deze tekst vóór de lancering door uw
          definitieve privacyverklaring conform de GDPR/AVG: welke gegevens u
          verzamelt, waarvoor, hoe lang u ze bewaart, met wie u ze deelt en
          welke rechten bezoekers hebben.
        </p>
        <p>
          Heeft u een vraag over uw gegevens? Mail gerust naar
          <a href={`mailto:${site.email}`}>{site.email}</a> of bel
          <a href={site.phoneHref}>{site.phone}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .privacy {
    max-width: var(--container-md);
  }
  .privacy__title {
    font-size: var(--text-2xl);
    margin: var(--space-3) 0 var(--space-5);
  }
</style>

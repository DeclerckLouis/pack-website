---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/Card.astro";
import Kicker from "@/components/Kicker.astro";
import Icon from "@/components/Icon.astro";
import Button from "@/components/Button.astro";
import { site } from "@/data/site";
import { breadcrumbs } from "@/lib/schema";

const jsonLd = breadcrumbs([
  ["Home", "/"],
  ["Contact", "/contact"],
]);

const contactItems = [
  ["phone", site.phone, site.phoneHref],
  ["mail", site.email, `mailto:${site.email}`],
  ["map-pin", `${site.address.city}, ${site.address.region}`, null],
];
---

<BaseLayout
  title="Contact — vrijblijvend kennismaken"
  description={`Neem contact op met ${site.name}. Bel ${site.phone}, mail ${site.email} of laat een bericht achter. Ik antwoord binnen één werkdag.`}
  jsonLd={jsonLd}
>
  <section class="section contact">
    <div class="container contact__grid">
      <div>
        <Kicker>Vrijblijvend kennismaken</Kicker>
        <h1 class="contact__title">30 minuten, kosteloos — bij u of via telefoon</h1>
        <p class="lead contact__lead">
          Vertel kort waar het schoentje knelt. Ik antwoord binnen één werkdag —
          vaak sneller. Geen verkooppraat, gewoon een eerlijk gesprek.
        </p>
        <div class="contact__list">
          {
            contactItems.map(([icon, text, href]) => (
              <div class="contact__item">
                <span class="contact__icon"><Icon name={icon} size={18} color="var(--blue-700)" /></span>
                {href ? <a href={href}>{text}</a> : <span>{text}</span>}
              </div>
            ))
          }
        </div>
        <p class="contact__avail">
          <Icon name="clock" size={15} /> Beschikbaar 's avonds en in het weekend.
        </p>
      </div>

      <Card raised>
        {/* TODO: koppel deze form aan een handler (Formspree, Netlify Forms,
            Cloudflare, of een eigen endpoint) en stel `action`/`method` in. */}
        <form class="contact-form" action="#" method="post">
          <label>
            <span class="contact-form__label">Naam</span>
            <input type="text" name="naam" placeholder="Uw naam of kantoor" required />
          </label>
          <label>
            <span class="contact-form__label">E-mail</span>
            <input type="email" name="email" placeholder="u@kantoor.be" required />
          </label>
          <label>
            <span class="contact-form__label">Waarmee kan ik helpen?</span>
            <textarea name="bericht" rows="4" placeholder="Vertel kort over uw situatie…"></textarea>
          </label>
          <Button type="submit" variant="primary" size="lg" fullWidth iconRight="send">
            Verstuur aanvraag
          </Button>
        </form>
      </Card>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .contact__title {
    font-size: var(--text-2xl);
    margin: var(--space-3) 0 var(--space-4);
  }
  .contact__lead {
    max-width: 44ch;
  }
  .contact__list {
    margin-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact__item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: var(--text-base);
    font-weight: var(--fw-medium);
    color: var(--text-strong);
  }
  .contact__icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    background: var(--blue-50);
    display: grid;
    place-content: center;
    flex: none;
  }
  .contact__avail {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .contact-form label {
    display: block;
  }
  .contact-form__label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    color: var(--text-strong);
    margin-bottom: 6px;
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-strong);
    background: var(--white);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: 11px 14px;
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--grey-400);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--orange-500);
    box-shadow: 0 0 0 3px var(--focus-ring);
  }
  .contact-form textarea {
    resize: vertical;
  }
  @media (max-width: 880px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { site } from "@/data/site";
import { url } from "@/lib/url";

interface Props {
  title: string;
  description?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Social share image, relative to the site root. */
  image?: string;
}

const { title, description = site.description, jsonLd, image = "/images/og-image.png" } =
  Astro.props;
// The homepage (title === site.name) gets a keyword-bearing <title> with geo +
// audience; inner pages keep the "{title} | Packetflow" pattern.
const fullTitle =
  title === site.name ? site.homeTitle : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogImage = new URL(url(image), Astro.site ?? Astro.url).href;
// Only the production host should be indexable. Staging (GitHub Pages) and
// Cloudflare preview builds resolve to a different hostname, so they get a
// noindex to avoid competing with packetflow.be as duplicate content.
const isProduction = (Astro.site?.hostname ?? "") === "www.packetflow.be";
---

<!doctype html>
<html lang="nl-BE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
    <link rel="canonical" href={canonical} />
    {!isProduction && <meta name="robots" content="noindex,nofollow" />}
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_BE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Naar inhoud</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

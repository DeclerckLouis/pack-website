---
import { site } from "@/data/site";
interface Props {
  title?: string;
  body?: string;
}
const {
  title = "Klaar voor een IT-partner die meedenkt?",
  body = "Plan een vrijblijvend gesprek. We kijken samen waar je staat en hoe we je kunnen ontzorgen.",
} = Astro.props;
---

<section class="container-page py-16">
  <div class="rounded-card bg-brand px-6 py-12 text-center text-white sm:px-12">
    <h2 class="mx-auto max-w-2xl text-2xl font-bold sm:text-3xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/80">{body}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/contact" class="btn bg-white text-brand hover:bg-white/90">
        Plan een gesprek
      </a>
      <a href={site.phoneHref} class="btn border border-white/30 text-white hover:bg-white/10">
        Bel {site.phone}
      </a>
    </div>
  </div>
</section>

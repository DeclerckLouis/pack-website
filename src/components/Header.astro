---
import { site, mainNav } from "@/data/site";
import { sectors } from "@/data/sectors";
import { services } from "@/data/services";
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { url } from "@/lib/url";

const path = Astro.url.pathname;
const isActive = (href: string) => {
  const h = url(href);
  return h === "/" ? path === h : path === h || path.startsWith(h + "/");
};

// Dropdown contents, keyed by the `dropdown` marker on a nav item. Each child
// keeps its own page, so these are plain links into the existing hubs.
type DropdownItem = { label: string; href: string; icon: string };
const dropdowns: Record<string, DropdownItem[]> = {
  sectors: sectors.map((s) => ({
    label: s.navTitle,
    href: `/sectoren/${s.slug}`,
    icon: s.icon,
  })),
  services: services.map((s) => ({
    label: s.navTitle,
    href: `/diensten/${s.slug}`,
    icon: s.icon,
  })),
};
---

<header class="site-header">
  <div class="site-header__in">
    <a href={url("/")} aria-label="Packetflow — home">
      <Logo variant="full" size={30} />
    </a>

    <nav class="site-nav" aria-label="Hoofdnavigatie">
      {
        mainNav.map((item) => {
          const children = "dropdown" in item ? dropdowns[item.dropdown] : undefined;
          if (!children) {
            return (
              <a
                href={url(item.href)}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={["site-nav__link", isActive(item.href) && "is-active"]}
              >
                {item.label}
              </a>
            );
          }
          return (
            <div class="site-nav__item">
              <a
                href={url(item.href)}
                aria-current={isActive(item.href) ? "page" : undefined}
                aria-haspopup="true"
                class:list={["site-nav__link", "site-nav__link--parent", isActive(item.href) && "is-active"]}
              >
                {item.label}
                <Icon name="chevron-down" size={15} class="site-nav__caret" />
              </a>
              <div class="site-nav__dropdown">
                <ul class="site-nav__menu" role="menu">
                  {children.map((c) => (
                    <li role="none">
                      <a
                        role="menuitem"
                        href={url(c.href)}
                        aria-current={isActive(c.href) ? "page" : undefined}
                        class:list={["site-nav__menu-link", isActive(c.href) && "is-active"]}
                      >
                        <span class="site-nav__menu-icon"><Icon name={c.icon} size={18} /></span>
                        <span class="site-nav__menu-title">{c.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          );
        })
      }
    </nav>

    <div class="site-header__actions">
      <a href={site.phoneHref} class="site-header__phone">
        <Icon name="phone" size={16} />
        {site.phone}
      </a>
      <Button href="/contact" variant="primary" size="sm">Plan een gesprek</Button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(251, 249, 244, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-soft);
  }
  .site-header__in {
    max-width: var(--container-lg);
    margin: 0 auto;
    padding: 14px var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }
  .site-nav {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .site-nav__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    color: var(--text-body);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--text-strong);
  }

  /* Dropdown parent */
  .site-nav__item {
    position: relative;
  }
  .site-nav__link--parent {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .site-nav__caret {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .site-nav__item:hover .site-nav__caret,
  .site-nav__item:focus-within .site-nav__caret {
    transform: rotate(180deg);
  }

  /* The flyout. `padding-top` is an invisible bridge so the menu doesn't
     close while the pointer travels from the link down to the panel. */
  .site-nav__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translate(-50%, 6px);
    padding-top: 12px;
    min-width: 230px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast) var(--ease-out);
  }
  .site-nav__item:hover .site-nav__dropdown,
  .site-nav__item:focus-within .site-nav__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .site-nav__menu {
    list-style: none;
    margin: 0;
    padding: 8px;
    background: var(--paper, #fff);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg, var(--shadow-md));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .site-nav__menu-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: var(--radius-sm, 8px);
    transition: background-color var(--dur-fast) var(--ease-out);
  }
  .site-nav__menu-link:hover,
  .site-nav__menu-link:focus-visible,
  .site-nav__menu-link.is-active {
    background: var(--surface-sunken, var(--cream));
  }
  .site-nav__menu-icon {
    flex: none;
    display: grid;
    place-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm, 8px);
    background: var(--cream);
    color: var(--primary);
  }
  .site-nav__menu-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    color: var(--text-strong);
    white-space: nowrap;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .site-header__phone {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    color: var(--text-strong);
  }

  @media (max-width: 880px) {
    .site-nav {
      display: none;
    }
  }
  @media (max-width: 560px) {
    .site-header__phone {
      display: none;
    }
  }
</style>
